{
    "name": "@diia-inhouse/scaffold",
    "version": "2.53.0",
    "main": "dist/index.js",
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "lint": "eslint . && prettier --check .",
        "lint-fix": "eslint . --fix && prettier --write .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "build": "rimraf dist && tsc && npm run cp:templates",
        "clean:result": "rimraf generation-result",
        "cp:templates": "cd src && copyfiles _templates/**/*.t ../dist && copyfiles _sharedTemplates/**/*.t ../dist",
        "prepare": "npm run build",
        "find-circulars": "madge --circular --extensions ts ./",
        "semantic-release": "semantic-release"
    },
    "bin": {
        "scaffold": "dist/bin.js"
    },
    "files": [
        "dist"
    ],
    "author": "Diia",
    "dependencies": {
        "@diia-inhouse/types": "11.5.0",
        "chalk": "4.1.2",
        "enquirer": "2.4.1",
        "execa": "5.1.1",
        "hygen": "6.2.11",
        "lodash": "4.17.23"
    },
    "devDependencies": {
        "@diia-inhouse/configs": "6.1.1",
        "@diia-inhouse/eslint-config": "8.4.0",
        "@types/lodash": "4.17.24",
        "@types/node": "25.3.3",
        "copyfiles": "2.4.1",
        "eslint": "9.33.0",
        "lockfile-lint": "4.14.1",
        "madge": "8.0.0",
        "prettier": "3.8.1",
        "rimraf": "6.1.3",
        "semantic-release": "24.2.3",
        "typescript": "5.9.3"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package",
        "branches": [
            "main"
        ]
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "prettier": "@diia-inhouse/eslint-config/prettier",
    "madge": {
        "tsConfig": "./tsconfig.json"
    },
    "repository": "https://github.com/diia-open-source/be-scaffold.git",
    "license": "SEE LICENCE IN LICENCE.md"
}
